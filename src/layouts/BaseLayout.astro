---
interface Props {
  title?: string
  description?: string
  canonicalPath?: string
  ogType?: string
}

const {
  title = 'Nicholas M. T. Elliott',
  description = 'Nicholas M.T. Elliott is an engineering leader focused on team building, delivery accountability, platform architecture, and production AI.',
  canonicalPath,
  ogType = 'website',
} = Astro.props
const currentPath = Astro.url.pathname
const canonicalUrl = new URL(canonicalPath ?? currentPath, 'https://nicholasmtelliott.com').toString()

const nav = [
  { href: '/', label: 'Home' },
  { href: '/case-studies/global-ag-platform', label: 'Global Case' },
  { href: '/ai', label: 'AI' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/about', label: 'Leadership' },
]

const isActive = (href: string) => {
  if (href === '/') {
    return currentPath === '/'
  }

  return currentPath.startsWith(href)
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://gravatar.com" />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="identity" href="/">
          <img
            class="identity__avatar"
            src="https://gravatar.com/avatar/468788fd550c4128b0c250566ea8729f?s=128"
            alt="Nicholas Elliott avatar"
          />
          <div>
            <p class="identity__name">Nicholas M.T. Elliott</p>
            <p>Founder · Engineering Leader · Platform Architect</p>
          </div>
        </a>
        <nav class="site-nav" aria-label="Primary navigation">
          {
            nav.map(link => (
              <a class={isActive(link.href) ? 'active' : ''} href={link.href}>
                {link.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>
    <main class="site-main">
      <slot />
    </main>
  </body>
</html>

<style is:global lang="scss">
  @use '../styles/global.scss';
</style>
