---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { syngentaArchitectureAreas, technologyEvidence } from '../../data/portfolio'

const outcomes = [
  'E-Luminate / GHX Fields: a few hundred advisors serving 10,000+ growers across the US and Canada.',
  'Cropwise: similar scale in international markets including Argentina, Brazil, Germany, Ukraine, and Hungary.',
  'Azure-to-AWS migration: 20 systems in six months, 25% lower burn rate, 75% faster deployments.',
  'Enterprise integrations with Salesforce, SAP, and a sales-hierarchy abstraction reused across regions.',
  'SOC 2 Type 2 passed in 2025, built on observability and processes the team already ran.',
  'Root Cause shipped to production in 2026: 90,000 fields analyzed weekly, reaching 90% of growers.',
]

const roleSignals = [
  'Led architecture and the engineering organization behind the platforms for fifteen years, 2011 through 2026.',
  'Owned architecture and modernization strategy across cloud, services, integrations, data, and UI.',
  'Led delivery across product stakeholders and engineering teams in the US, India, Brazil, Egypt, and Europe.',
  'Mentored and planned the handoff so Syngenta’s internal teams could own the platforms outright.',
]

const timeline = [
  ['2011', 'Engagement begins: E-Luminate, a regional sustainability and recommendation tool.'],
  ['2017', 'The platform becomes central to North America Seeds digital recommendations; later rebranded GHX Fields.'],
  ['2020s', 'Cropwise extends the work internationally. Stack modernizes to TypeScript/React, .NET Core, Node.js, and AWS.'],
  ['2025', 'SOC 2 Type 2 passed, following the six-month migration of 20 systems to AWS.'],
  ['2026', 'Root Cause AI ships; platforms transition to Syngenta’s internal teams.'],
]
---

<BaseLayout
  title="Nicholas M. T. Elliott | Global Agricultural Platform Case Study"
  description="Case study on enterprise platform delivery, distributed engineering leadership, AWS modernization, observability, integrations, and production AI for Syngenta-scale agricultural systems."
  ogType="article"
  preloadImage="/images/generated/ag-platform-architecture.webp"
>
  <article class="case-study">
    <header class="case-hero">
      <div>
        <p class="eyebrow">Case study · Syngenta, 2011–2026</p>
        <h1>Global Agricultural Recommendation Platform</h1>
        <p>
          Fifteen years building E-Luminate, GHX Fields, and Cropwise for Syngenta: from a regional sustainability
          tool to seed-recommendation systems that a few hundred advisors use to serve 10,000+ growers per platform,
          across North America, South America, and Europe. Some details stay at category level out of respect for
          client confidentiality.
        </p>
        <div class="button-row">
          <a class="button" href="/contact/leadership/">Tell me about the role</a>
          <a class="button-secondary" href="/ai">See the AI layer</a>
        </div>
      </div>
      <aside class="case-summary card">
        <p class="eyebrow">Scope at a glance</p>
        <dl>
          <div><dt>Program</dt><dd>Syngenta · global agribusiness · 2011–2026</dd></div>
          <div><dt>Reach</dt><dd>10,000+ growers per platform, across three continents</dd></div>
          <div><dt>Systems</dt><dd>Web apps, APIs, AWS, Salesforce/SAP integrations, observability, AI</dd></div>
          <div><dt>My role</dt><dd>Architect, engineering org lead, delivery owner, mentor</dd></div>
        </dl>
      </aside>
    </header>

    <section class="section">
      <div class="section-heading">
        <p class="eyebrow">The problem</p>
        <h2>Every region farms differently</h2>
        <p>
          A seed recommendation depends on agronomic data, weather, product catalogs, territory rules, discounts, and
          sales hierarchies — and every one of those works differently in Iowa, Mato Grosso, and Hungary. Building a
          separate app per market would have buried the team in duplicate work. The durable value was a set of
          platform abstractions that absorbed regional differences instead of multiplying them.
        </p>
      </div>
    </section>

    <section class="section architecture">
      <div class="section-heading">
        <p class="eyebrow">Architecture</p>
        <h2>The shape of the platform</h2>
      </div>
      <div class="architecture-grid">
        {
          syngentaArchitectureAreas.map(area => (
            <article class="architecture-card card">
              <h3>{area.title}</h3>
              <p>{area.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section role-impact">
      <div class="section-heading">
        <p class="eyebrow">My role</p>
        <h2>What I was accountable for</h2>
      </div>
      <div class="role-grid">
        {
          roleSignals.map(signal => (
            <article class="card">
              <p>{signal}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="section-heading">
        <p class="eyebrow">Outcomes</p>
        <h2>What the numbers say</h2>
      </div>
      <ul class="outcome-list">
        {outcomes.map(outcome => <li>{outcome}</li>)}
      </ul>
    </section>

    <section class="section timeline-section">
      <div class="section-heading">
        <p class="eyebrow">Timeline</p>
        <h2>Fifteen years in five steps</h2>
      </div>
      <div class="timeline">
        {
          timeline.map(([label, body]) => (
            <article>
              <strong>{label}</strong>
              <p>{body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="section-heading">
        <p class="eyebrow">Technology</p>
        <h2>The stack, with receipts</h2>
      </div>
      <div class="tech-grid">
        {
          technologyEvidence.filter(item => item.scope === 'syngenta').map(item => (
            <article class="card">
              <h3>{item.area}</h3>
              <p class="tools">{item.tools}</p>
              <p>{item.proof}</p>
            </article>
          ))
        }
      </div>
    </section>
  </article>
</BaseLayout>

<style lang="scss">
  .case-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
    gap: clamp(1rem, 3vw, 2rem);
    padding-top: clamp(1rem, 3vw, 2rem);
  }

  .case-hero > div {
    min-height: clamp(500px, 68vh, 720px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: clamp(1.35rem, 4vw, 3rem);
    background:
      linear-gradient(rgba(13, 16, 23, 0.2), rgba(13, 16, 23, 0.92)),
      url('/images/generated/ag-platform-architecture.webp') center / cover;
    box-shadow: var(--shadow);
  }

  .case-hero h1 {
    max-width: 12ch;
    margin: 0.7rem 0 1rem;
    font-size: clamp(2.9rem, 6.8vw, 5.6rem);
    line-height: 0.92;
  }

  .case-hero p {
    max-width: 72ch;
    color: color-mix(in srgb, var(--text) 84%, var(--muted) 16%);
    font-size: clamp(1rem, 1.7vw, 1.2rem);
  }

  .case-summary {
    align-self: stretch;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  dl {
    display: grid;
    gap: 1rem;
    margin: 1rem 0 0;
  }

  dl div {
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }

  dt {
    color: var(--accent-warm);
    font-weight: 800;
  }

  dd {
    margin: 0.3rem 0 0;
    color: var(--muted);
  }

  .section {
    margin-top: clamp(2.2rem, 5vw, 4rem);
  }

  .architecture {
    border-block: 1px solid var(--border);
    padding-block: clamp(1.5rem, 4vw, 3rem);
  }

  .architecture-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .architecture-card {
    min-height: 230px;
  }

  .architecture-card h3,
  .role-grid h3,
  .tech-grid h3 {
    margin: 0 0 0.75rem;
  }

  .architecture-card p,
  .role-grid p,
  .tech-grid p {
    color: var(--muted);
  }

  .role-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .outcome-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.8rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .outcome-list li {
    border: 1px solid var(--border);
    background: var(--surface);
    border-radius: var(--radius);
    padding: 1rem;
    color: var(--muted);
  }

  .timeline {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface);
  }

  .timeline article {
    padding: 1rem;
    border-right: 1px solid var(--border);
  }

  .timeline article:last-child {
    border-right: 0;
  }

  .timeline strong {
    color: var(--accent-warm);
  }

  .timeline p {
    margin: 0.45rem 0 0;
    color: var(--muted);
  }

  .tech-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .tech-grid .tools {
    color: var(--accent-soft);
    font-size: 0.9rem;
  }

  @media (max-width: 980px) {
    .case-hero,
    .architecture-grid,
    .role-grid,
    .tech-grid {
      grid-template-columns: 1fr 1fr;
    }

    .case-hero > div,
    .case-summary {
      grid-column: 1 / -1;
    }

    .timeline,
    .outcome-list {
      grid-template-columns: 1fr;
    }

    .timeline article {
      border-right: 0;
      border-bottom: 1px solid var(--border);
    }
  }

  @media (max-width: 640px) {
    .case-hero,
    .architecture-grid,
    .role-grid,
    .tech-grid {
      grid-template-columns: 1fr;
    }

    .case-hero h1 {
      max-width: 12ch;
      font-size: clamp(2.45rem, 15vw, 4rem);
    }
  }
</style>
