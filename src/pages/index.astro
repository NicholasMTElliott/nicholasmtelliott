---
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import EmailObfuscated from '../components/EmailObfuscated.astro'
import SignalGlyph from '../components/SignalGlyph.astro'
import { hardProblems, proofMetrics, selectedAchievements, valuePillars } from '../data/portfolio'

const profileEntry = (await getCollection('profile'))[0]
const contactEntry = (await getCollection('contact'))[0]
const defaultAvatarUrl = 'https://gravatar.com/avatar/468788fd550c4128b0c250566ea8729f?s=160'
const displayEmail = contactEntry ? `${contactEntry.data.emailLocal}@${contactEntry.data.emailDomain}` : null

if (!profileEntry) {
  throw new Error('Required profile content is missing.')
}

const careerSignals = [
  ['Skyward', 'Founded 2010, profitable every year since'],
  ['Syngenta', '15-year platform partnership, 2011–2026'],
  ['10,000+', 'Growers served per platform, three continents'],
  ['Global Teams', 'US, India, Brazil, Egypt, Europe'],
  ['Microsoft', 'Visio layers, indexing, theming, 2003–2006'],
]
---

<BaseLayout
  title="Nicholas M. T. Elliott | Engineering Leadership"
  description="Founder of Skyward App Company and fifteen-year technical lead for Syngenta's seed-recommendation platforms. Teams, platform modernization, and production AI."
>
  <section class="hero">
    <div class="hero__content">
      <p class="eyebrow">Nicholas M.T. Elliott · Engineering Leader</p>
      <h1>Teams and platforms that last.</h1>
      <p class="hero__lead">
        I founded Skyward App Company in 2010 and ran it profitably for sixteen years. For fifteen of them, I led
        Syngenta's seed-recommendation platforms — from a regional sustainability tool to systems serving 10,000+
        growers across three continents. I built the team, made the architecture calls, and still write code.
      </p>
      <div class="button-row">
        <a class="button" href="/case-studies/global-ag-platform">Read the case study</a>
        <a class="button-secondary" href="/contact/leadership/control/">Contact me</a>
        <a class="button-secondary" href={profileEntry.data.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
      </div>
      {displayEmail && (
        <div class="hero__email">
          <EmailObfuscated displayEmail={displayEmail} aliasTag="bot" />
        </div>
      )}
    </div>

    <aside class="proof card" aria-label="Career proof points">
      <img class="proof__avatar" src={profileEntry.data.avatarUrl ?? defaultAvatarUrl} alt={profileEntry.data.fullName} />
      <div>
        <p class="eyebrow">At a glance</p>
        <h3>Nicholas M.T. Elliott</h3>
        <p>{profileEntry.data.headline} · {profileEntry.data.location}</p>
      </div>
      <ul>
        {
          proofMetrics.map(metric => (
            <li>
              <strong>{metric.value}</strong>
              <span>{metric.label}</span>
            </li>
          ))
        }
      </ul>
    </aside>
  </section>

  <section class="signal-strip" aria-label="Career evidence">
    {
      careerSignals.map(([label, detail]) => (
        <article>
          <strong>{label}</strong>
          <span>{detail}</span>
        </article>
      ))
    }
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Track record</p>
      <h2>Selected work</h2>
    </div>
    <div class="achievement-grid">
      {
        selectedAchievements.map(achievement => (
          <article class="achievement card">
            <h3>{achievement.title}</h3>
            <dl>
              <div>
                <dt>Role</dt>
                <dd>{achievement.role}</dd>
              </div>
              <div>
                <dt>Outcome</dt>
                <dd>{achievement.outcome}</dd>
              </div>
              <div>
                <dt>Scale</dt>
                <dd>{achievement.scale}</dd>
              </div>
            </dl>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">How I work</p>
      <h2>Four things I keep doing</h2>
    </div>
    <div class="pillar-grid">
      {
        valuePillars.map(pillar => (
          <article class="pillar card">
            <SignalGlyph type={pillar.icon} label={`${pillar.title} signal glyph`} />
            <h3>{pillar.title}</h3>
            <p>{pillar.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section featured-case">
    <div class="case-visual card">
      <p class="eyebrow">Case study</p>
      <h2>Fifteen years with one client</h2>
      <p>Syngenta's E-Luminate, GHX Fields, and Cropwise platforms, 2011–2026.</p>
    </div>
    <div class="case-copy">
      <div class="section-heading">
        <p class="eyebrow">Syngenta · E-Luminate / GHX Fields / Cropwise</p>
        <h2>From regional tool to global seed-recommendation platform</h2>
        <p>
          What started as a regional sustainability app became Syngenta's digital seed-recommendation system: a few
          hundred advisors using it to serve 10,000+ growers in the US and Canada, with Cropwise carrying similar
          scale into Argentina, Brazil, Germany, Ukraine, Hungary, and other markets. Along the way we rebuilt it from
          .NET Framework and Knockout on Azure into TypeScript/React and .NET Core/Node.js services on AWS.
        </p>
      </div>
      <div class="case-points">
        <article>
          <span class="eyebrow">Migration</span>
          <p>20 systems moved from Azure to AWS in six months — 25% lower burn rate, 75% faster deployments.</p>
        </article>
        <article>
          <span class="eyebrow">Integrations</span>
          <p>Salesforce, SAP, and a shared sales-hierarchy abstraction spanning regional commercial models.</p>
        </article>
        <article>
          <span class="eyebrow">Operations</span>
          <p>OpenTelemetry instrumentation end to end; the same telemetry carried us through SOC 2 Type 2 in 2025.</p>
        </article>
      </div>
      <a class="button" href="/case-studies/global-ag-platform">Open detailed case study</a>
    </div>
  </section>

  <section class="section story-bank">
    <div class="section-heading">
      <p class="eyebrow">Career depth</p>
      <h2>Hard problems I've owned</h2>
      <p>
        Twenty-five years of shipping means a few stories. These are the ones I still get asked about.
      </p>
    </div>
    <div class="story-grid">
      {
        hardProblems.map(story => (
          <article class="story">
            <h3>{story.title}</h3>
            <p>{story.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section ai-preview">
    <div class="section-heading">
      <p class="eyebrow">AI in production</p>
      <h2>90,000 fields a week</h2>
      <p>
        Root Cause, the AI feature my team shipped for Syngenta in 2026, analyzes 90,000 grower fields weekly and
        surfaces concerns with suggested mitigations. I also run AI-assisted engineering practices and local-model
        experiments — details on the AI page.
      </p>
    </div>
    <div class="button-row">
      <a class="button" href="/ai">View AI work</a>
      <a class="button-secondary" href="/portfolio">Browse full portfolio</a>
    </div>
  </section>

</BaseLayout>

<style lang="scss">
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.18fr) minmax(310px, 0.82fr);
    gap: clamp(1rem, 3vw, 2.4rem);
    align-items: stretch;
    min-height: clamp(560px, 72vh, 760px);
    padding: clamp(1.1rem, 3vw, 2.25rem) 0 0;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 100%;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: clamp(1.35rem, 4vw, 3.2rem);
    background-image: linear-gradient(rgba(13, 16, 23, 0.1), rgba(13, 16, 23, 0.9)),
      url('/images/generated/enterprise-hero.webp');
    background-size: cover;
    background-position: center;
    box-shadow: var(--shadow);
  }

  .hero h1 {
    max-width: 13ch;
    margin: 0.7rem 0 1rem;
    font-size: clamp(3rem, 7vw, 5.9rem);
    line-height: 0.92;
  }

  .hero__lead {
    max-width: 68ch;
    color: color-mix(in srgb, var(--text) 86%, var(--muted) 14%);
    font-size: clamp(1.02rem, 1.8vw, 1.26rem);
    margin: 0 0 1.3rem;
  }

  .hero__email {
    margin-top: 1rem;
  }

  .proof {
    display: grid;
    align-content: start;
    gap: 1.1rem;
  }

  .proof__avatar {
    width: clamp(74px, 8vw, 96px);
    height: clamp(74px, 8vw, 96px);
    border-radius: 50%;
    border: 2px solid color-mix(in srgb, var(--accent) 48%, transparent);
  }

  .proof h3 {
    margin: 0.35rem 0 0;
    font-size: clamp(1.35rem, 2vw, 1.7rem);
  }

  .proof p {
    margin: 0.25rem 0 0;
    color: var(--muted);
  }

  .proof ul {
    display: grid;
    gap: 0.85rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .proof li {
    display: grid;
    grid-template-columns: minmax(74px, 0.3fr) 1fr;
    gap: 0.9rem;
    border-top: 1px solid var(--border);
    padding-top: 0.85rem;
  }

  .proof strong {
    color: var(--accent-warm);
    font-size: clamp(1.25rem, 2.4vw, 1.7rem);
    line-height: 1;
  }

  .proof span {
    color: var(--muted);
  }

  .signal-strip {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    margin-top: clamp(1rem, 2vw, 1.4rem);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: color-mix(in srgb, var(--surface) 78%, #000 22%);
  }

  .signal-strip article {
    padding: 1rem;
    border-right: 1px solid var(--border);
  }

  .signal-strip article:last-child {
    border-right: 0;
  }

  .signal-strip strong,
  .signal-strip span {
    display: block;
  }

  .signal-strip span {
    color: var(--muted);
    font-size: 0.88rem;
    margin-top: 0.2rem;
  }

  .section {
    margin-top: clamp(2.2rem, 5vw, 4.2rem);
  }

  .achievement-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .achievement {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .achievement h3 {
    margin: 0;
    font-size: clamp(1.2rem, 2vw, 1.55rem);
  }

  .achievement dl {
    display: grid;
    gap: 0.85rem;
    margin: 0;
  }

  .achievement dl div {
    border-top: 1px solid var(--border);
    padding-top: 0.85rem;
  }

  .achievement dt {
    color: var(--accent-warm);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .achievement dd {
    margin: 0.25rem 0 0;
    color: var(--muted);
  }

  .pillar-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .pillar {
    min-height: 210px;
  }

  .pillar {
    display: grid;
    align-content: start;
    gap: 0.75rem;
    position: relative;
    overflow: hidden;
    transition:
      border-color 140ms ease,
      background-color 140ms ease,
      transform 140ms ease;
  }

  .pillar::after {
    content: '';
    position: absolute;
    inset: auto 0 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--accent) 45%, transparent), transparent);
    opacity: 0;
    transition: opacity 140ms ease;
  }

  .pillar:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--border) 52%, var(--accent) 48%);
    background: color-mix(in srgb, var(--surface) 88%, var(--surface-alt) 12%);
  }

  .pillar:hover::after {
    opacity: 1;
  }

  .pillar h3 {
    margin: 0 0 0.75rem;
  }

  .pillar p {
    color: var(--muted);
  }

  .featured-case {
    display: grid;
    grid-template-columns: minmax(280px, 0.82fr) minmax(0, 1.18fr);
    gap: clamp(1rem, 3vw, 2rem);
  }

  .case-visual {
    min-height: 410px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background:
      linear-gradient(rgba(13, 16, 23, 0.08), rgba(13, 16, 23, 0.88)),
      url('/images/generated/ag-platform-architecture.webp') center / cover;
  }

  .case-visual h2 {
    margin: 0.5rem 0;
    font-size: clamp(1.8rem, 3.6vw, 3rem);
  }

  .case-visual p {
    margin: 0;
    color: color-mix(in srgb, var(--text) 82%, var(--muted) 18%);
  }

  .case-copy {
    align-self: center;
  }

  .case-points {
    display: grid;
    gap: 0.85rem;
    margin: 1.25rem 0;
  }

  .case-points article {
    border-top: 1px solid var(--border);
    padding-top: 0.85rem;
  }

  .case-points p {
    margin: 0.3rem 0 0;
    color: var(--muted);
  }

  .ai-preview {
    border-block: 1px solid var(--border);
    padding-block: clamp(1.5rem, 4vw, 2.8rem);
  }

  .story-bank {
    border-block: 1px solid var(--border);
    padding-block: clamp(1.5rem, 4vw, 2.8rem);
  }

  .story-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .story {
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }

  .story h3 {
    margin: 0 0 0.5rem;
  }

  .story p {
    margin: 0;
    color: var(--muted);
  }

  @media (max-width: 980px) {
    .hero,
    .featured-case {
      grid-template-columns: 1fr;
      min-height: 0;
    }

    .achievement-grid,
    .signal-strip,
    .pillar-grid,
    .story-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .signal-strip article:nth-child(2n) {
      border-right: 0;
    }
  }

  @media (max-width: 640px) {
    .hero h1 {
      max-width: 12ch;
      font-size: clamp(2.55rem, 16vw, 4rem);
    }

    .achievement-grid,
    .signal-strip,
    .pillar-grid,
    .story-grid {
      grid-template-columns: 1fr;
    }

    .signal-strip article {
      border-right: 0;
      border-bottom: 1px solid var(--border);
    }

    .signal-strip article:last-child {
      border-bottom: 0;
    }
  }
</style>
