---
import { getCollection, render } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { technologyEvidence } from '../../data/portfolio'

const companyEntries = (await getCollection('company')).sort(
  (a, b) => {
    const aEnd = a.data.endDate?.getTime() ?? Number.POSITIVE_INFINITY
    const bEnd = b.data.endDate?.getTime() ?? Number.POSITIVE_INFINITY

    if (aEnd !== bEnd) {
      return bEnd - aEnd
    }

    return b.data.startDate.getTime() - a.data.startDate.getTime()
  },
)

const roleEntries = await getCollection('role')
const projectEntries = await getCollection('project')

const rolesByCompanyKey = roleEntries.reduce<Record<string, typeof roleEntries>>((acc, role) => {
  const current = acc[role.data.companyKey] ?? []
  current.push(role)
  acc[role.data.companyKey] = current

  return acc
}, {})

Object.values(rolesByCompanyKey).forEach(roles => {
  roles.sort((a, b) => {
    const aEnd = a.data.endDate?.getTime() ?? Number.POSITIVE_INFINITY
    const bEnd = b.data.endDate?.getTime() ?? Number.POSITIVE_INFINITY

    if (aEnd !== bEnd) {
      return bEnd - aEnd
    }

    return b.data.startDate.getTime() - a.data.startDate.getTime()
  })
})

const projectsByRoleKey = projectEntries.reduce<Record<string, typeof projectEntries>>((acc, project) => {
  const current = acc[project.data.roleKey] ?? []
  current.push(project)
  acc[project.data.roleKey] = current

  return acc
}, {})

Object.values(projectsByRoleKey).forEach(projects => {
  projects.sort((a, b) => {
    const featuredDelta = Number(b.data.featured ?? false) - Number(a.data.featured ?? false)

    if (featuredDelta !== 0) {
      return featuredDelta
    }

    const aEnd = a.data.endDate?.getTime() ?? Number.POSITIVE_INFINITY
    const bEnd = b.data.endDate?.getTime() ?? Number.POSITIVE_INFINITY

    if (aEnd !== bEnd) {
      return bEnd - aEnd
    }

    const aStart = a.data.startDate?.getTime() ?? Number.NEGATIVE_INFINITY
    const bStart = b.data.startDate?.getTime() ?? Number.NEGATIVE_INFINITY

    return bStart - aStart
  })
})

const renderedCompanyEntries = await Promise.all(
  companyEntries.map(async company => {
    const { Content } = await render(company)
    const companyRoles = rolesByCompanyKey[company.data.key] ?? []

    const renderedRoles = await Promise.all(
      companyRoles.map(async role => {
        const { Content: RoleContent } = await render(role)
        const roleProjects = projectsByRoleKey[role.data.key] ?? []

        const renderedProjects = await Promise.all(
          roleProjects.map(async project => {
            const { Content: ProjectContent } = await render(project)

            return {
              project,
              ProjectContent,
            }
          }),
        )

        return {
          role,
          RoleContent,
          renderedProjects,
        }
      }),
    )

    return {
      company,
      Content,
      renderedRoles,
    }
  }),
)

const formatMonthYear = (date: Date) =>
  `${date.toLocaleString('en-US', { month: 'short', timeZone: 'UTC' })} ${date.getUTCFullYear()}`

// Eras before Prophetic Sky predate reliable month-level records; show years only.
const yearOnlyEras = new Set(['zedx', 'microsoft'])

const formatPeriod = (startDate: Date, endDate?: Date, yearOnly = false) => {
  const format = yearOnly ? (date: Date) => `${date.getUTCFullYear()}` : formatMonthYear
  const start = format(startDate)
  const end = endDate ? format(endDate) : 'Present'

  return start === end ? start : `${start} - ${end}`
}

const eraYears = (startDate: Date, endDate?: Date) =>
  endDate ? `${startDate.getUTCFullYear()}–${endDate.getUTCFullYear()}` : `${startDate.getUTCFullYear()}–`

interface EraMeta {
  accent: string
  epigraph: string
  image: string
}

const eraMeta: Record<string, EraMeta> = {
  'skyward-app-company': {
    accent: '#69d2a1',
    epigraph: 'Profitable all sixteen years — and built to be handed off.',
    image: '/images/generated/era-skyward.webp',
  },
  'prophetic-sky': {
    accent: '#f1c65b',
    epigraph: 'Self-funded products keep scope honest.',
    image: '/images/generated/era-prophetic-sky.webp',
  },
  microsoft: {
    accent: '#60a5fa',
    epigraph: 'Features shipped end to end, inside a famously disciplined release process.',
    image: '/images/generated/era-microsoft.webp',
  },
  zedx: {
    accent: '#a78bfa',
    epigraph: 'A terabyte a day, tamed with a custom storage engine.',
    image: '/images/generated/era-zedx.webp',
  },
}

const projectStats: Record<string, Array<{ value: string; label: string }>> = {
  'e-luminate-ghx-fields-syngenta': [
    { value: '15 yrs', label: 'one platform partnership' },
    { value: '10,000+', label: 'growers served, US & Canada' },
    { value: '90k', label: 'fields analyzed weekly by AI' },
    { value: '20', label: 'systems to AWS in six months' },
  ],
  'precision-ag-modeling-platform': [
    { value: '1TB → 12GB', label: 'daily data growth, after my custom storage engine' },
    { value: '20min → 20s', label: 'average processing time' },
    { value: 'Early 2000s', label: 'GPS field devices, pre-smartphone' },
  ],
}

const projectLinks: Record<string, { href: string; label: string }> = {
  'e-luminate-ghx-fields-syngenta': {
    href: '/case-studies/global-ag-platform',
    label: 'Read the full case study',
  },
}

const portfolioSections = [
  ['#highlights', 'Highlights'],
  ['#timeline', 'Timeline'],
  ['#technology', 'Technology'],
]

const highlights = [
  ['Founder/operator', 'Skyward: one person to 30, profitable all sixteen years'],
  ['Enterprise delivery', "Fifteen years owning Syngenta's recommendation platforms"],
  ['Distributed teams', 'US, India, Brazil, Egypt, and Europe'],
  ['Still technical', 'Custom MySQL storage engine to AWS CDK and LLM pipelines'],
]
---

<BaseLayout
  title="Nicholas M. T. Elliott | Portfolio"
  description="Career timeline and project portfolio for Nicholas M.T. Elliott: 25 years across ZedX, Microsoft, Prophetic Sky, and Skyward App Company."
>
  <section class="portfolio">
    <header class="portfolio__header">
      <p class="eyebrow">Portfolio</p>
      <h1>Twenty-five years of shipping.</h1>
      <p>
        Four eras, newest first: Skyward and the Syngenta platforms, the self-funded studio years, Microsoft, and the
        weather systems where it all started.
      </p>
      <nav class="portfolio-nav" aria-label="Portfolio sections">
        {portfolioSections.map(([href, label]) => <a href={href}>{label}</a>)}
      </nav>
    </header>

    <section class="highlight-strip" id="highlights" aria-label="Career highlights">
      {
        highlights.map(([label, detail]) => (
          <article>
            <strong>{label}</strong>
            <span>{detail}</span>
          </article>
        ))
      }
    </section>

    <div class="timeline" id="timeline">
      {
        renderedCompanyEntries.map(({ company, Content, renderedRoles }) => {
          const meta = eraMeta[company.data.key]

          return (
            <section class="era" id={company.data.key} style={`--era: ${meta?.accent ?? 'var(--accent)'}`}>
              <header
                class="era__head"
                style={meta ? `background-image: linear-gradient(rgba(13, 16, 23, 0.45), rgba(13, 16, 23, 0.94)), url(${meta.image})` : undefined}
              >
                <span class="era__years">{eraYears(company.data.startDate, company.data.endDate)}</span>
                <div class="era__id">
                  <h2>{company.data.title}</h2>
                  <p class="era__meta">
                    {formatPeriod(company.data.startDate, company.data.endDate, yearOnlyEras.has(company.data.key))}
                    {company.data.location && ` · ${company.data.location}`}
                  </p>
                </div>
              </header>

              <div class="era__rail">
                <div class="era__intro">
                  <Content />
                </div>
                {meta && <p class="era__epigraph">{meta.epigraph}</p>}

                {renderedRoles.map(({ role, RoleContent, renderedProjects }) => (
                  <div class="role">
                    <header class="role__head">
                      <h3>{role.data.title}</h3>
                      <p>
                        {formatPeriod(role.data.startDate, role.data.endDate, yearOnlyEras.has(company.data.key))}
                        {role.data.employmentType && ` · ${role.data.employmentType}`}
                      </p>
                    </header>
                    <div class="role__body">
                      <RoleContent />
                    </div>

                    {renderedProjects.length > 0 && (
                      <div class="projects">
                        {renderedProjects.map(({ project, ProjectContent }) => {
                          const stats = projectStats[project.data.key]
                          const link = projectLinks[project.data.key]
                          const period =
                            project.data.startDate &&
                            formatPeriod(project.data.startDate, project.data.endDate, yearOnlyEras.has(company.data.key))

                          return project.data.featured ? (
                            <article class="feature">
                              <header class="feature__head">
                                <p class="eyebrow">Featured</p>
                                <h4>{project.data.name}</h4>
                                {period && <p class="proj-period">{period}</p>}
                              </header>
                              {stats && (
                                <ul class="feature__stats">
                                  {stats.map(stat => (
                                    <li>
                                      <strong>{stat.value}</strong>
                                      <span>{stat.label}</span>
                                    </li>
                                  ))}
                                </ul>
                              )}
                              <div class="feature__body">
                                <ProjectContent />
                              </div>
                              {project.data.skills && (
                                <div class="tag-list">
                                  {project.data.skills.map(skill => (
                                    <span class="tag">{skill}</span>
                                  ))}
                                </div>
                              )}
                              {link && (
                                <a class="feature__link" href={link.href}>
                                  {link.label} →
                                </a>
                              )}
                            </article>
                          ) : (
                            <details class="proj">
                              <summary>
                                <span class="proj__name">{project.data.name}</span>
                                {period && <span class="proj-period">{period}</span>}
                                {project.data.skills && (
                                  <span class="proj__skills">{project.data.skills.slice(0, 3).join(' · ')}</span>
                                )}
                                <span class="proj__chevron" aria-hidden="true">+</span>
                              </summary>
                              <div class="proj__body">
                                <ProjectContent />
                              </div>
                            </details>
                          )
                        })}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </section>
          )
        })
      }
    </div>

    <section class="tech-section" id="technology">
      <div class="section-heading">
        <p class="eyebrow">Technology</p>
        <h2>Tools, with the work to back them</h2>
      </div>
      <div class="tech-map">
        {
          technologyEvidence.map(item => (
            <article>
              <h3>{item.area}</h3>
              <p class="tools">{item.tools}</p>
              <p>{item.proof}</p>
            </article>
          ))
        }
      </div>
    </section>
  </section>
</BaseLayout>

<style lang="scss">
  .portfolio__header {
    padding-top: clamp(0.8rem, 2.5vw, 1.8rem);
  }

  .portfolio__header h1 {
    margin: 0.6rem 0 0.9rem;
    font-size: clamp(2.4rem, 5.5vw, 4.4rem);
    line-height: 0.95;
  }

  .portfolio__header > p:not(.eyebrow) {
    max-width: 70ch;
    margin: 0;
    color: var(--muted);
    font-size: clamp(1rem, 1.6vw, 1.15rem);
  }

  .portfolio-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.2rem;
  }

  .portfolio-nav a {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--surface);
    color: var(--text);
    text-decoration: none;
    font-size: 0.9rem;
  }

  .portfolio-nav a:hover {
    border-color: color-mix(in srgb, var(--border) 55%, var(--accent) 45%);
  }

  .highlight-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    margin-top: clamp(1.2rem, 2.5vw, 1.8rem);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: color-mix(in srgb, var(--surface) 78%, #000 22%);
  }

  .highlight-strip article {
    padding: 1rem;
    border-right: 1px solid var(--border);
  }

  .highlight-strip article:last-child {
    border-right: 0;
  }

  .highlight-strip strong,
  .highlight-strip span {
    display: block;
  }

  .highlight-strip span {
    color: var(--muted);
    font-size: 0.88rem;
    margin-top: 0.2rem;
  }

  .timeline {
    margin-top: clamp(2rem, 4.5vw, 3.4rem);
    display: grid;
    gap: clamp(2.2rem, 5vw, 4rem);
  }

  .era__head {
    display: flex;
    align-items: flex-end;
    gap: clamp(1rem, 3vw, 2.2rem);
    min-height: clamp(170px, 24vh, 250px);
    padding: clamp(1rem, 2.5vw, 1.6rem);
    border: 1px solid color-mix(in srgb, var(--border) 70%, var(--era) 30%);
    border-radius: var(--radius);
    background-size: cover;
    background-position: center;
    box-shadow: var(--shadow);
  }

  .era__years {
    color: var(--era);
    font-size: clamp(2.4rem, 6vw, 4.6rem);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: -0.03em;
    white-space: nowrap;
  }

  .era__id h2 {
    margin: 0;
    font-size: clamp(1.4rem, 2.6vw, 2.1rem);
  }

  .era__meta {
    margin: 0.3rem 0 0;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .era__rail {
    position: relative;
    margin: clamp(0.9rem, 2vw, 1.3rem) 0 0 clamp(0.4rem, 1.5vw, 1.1rem);
    padding-left: clamp(1rem, 2.5vw, 1.8rem);
    border-left: 2px solid color-mix(in srgb, var(--era) 45%, var(--border));
    display: grid;
    gap: 1.1rem;
  }

  .era__rail::before {
    content: '';
    position: absolute;
    top: 0;
    left: -7px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--era);
  }

  .era__intro :global(p) {
    margin: 0 0 0.7rem;
    color: var(--muted);
    max-width: 74ch;
  }

  .era__intro :global(p:last-child) {
    margin-bottom: 0;
  }

  .era__epigraph {
    margin: 0;
    padding-left: 1rem;
    border-left: 3px solid var(--era);
    color: var(--text);
    font-size: clamp(1.05rem, 1.8vw, 1.3rem);
    font-weight: 650;
    max-width: 56ch;
  }

  .role {
    border-top: 1px solid var(--border);
    padding-top: 1rem;
    display: grid;
    gap: 0.7rem;
  }

  .role__head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.3rem 0.9rem;
  }

  .role__head h3 {
    margin: 0;
    font-size: clamp(1.12rem, 1.9vw, 1.4rem);
  }

  .role__head p {
    margin: 0;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .role__body :global(p) {
    margin: 0;
    color: var(--muted);
    max-width: 74ch;
  }

  .projects {
    display: grid;
    gap: 0.6rem;
    margin-top: 0.3rem;
  }

  .feature {
    border: 1px solid color-mix(in srgb, var(--border) 60%, var(--era) 40%);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow);
    padding: clamp(1rem, 2vw, 1.4rem);
    display: grid;
    gap: 0.9rem;
  }

  .feature .eyebrow {
    margin: 0;
    color: var(--era);
  }

  .feature__head h4 {
    margin: 0.25rem 0 0;
    font-size: clamp(1.25rem, 2.2vw, 1.65rem);
  }

  .proj-period {
    margin: 0.25rem 0 0;
    color: var(--muted);
    font-size: 0.85rem;
  }

  .feature__stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: color-mix(in srgb, var(--surface-alt) 70%, #000 30%);
  }

  .feature__stats li {
    padding: 0.75rem 0.9rem;
    border-right: 1px solid var(--border);
  }

  .feature__stats li:last-child {
    border-right: 0;
  }

  .feature__stats strong {
    display: block;
    color: var(--era);
    font-size: clamp(1.15rem, 2vw, 1.5rem);
    line-height: 1.1;
  }

  .feature__stats span {
    display: block;
    margin-top: 0.2rem;
    color: var(--muted);
    font-size: 0.82rem;
  }

  .feature__body :global(p) {
    margin: 0 0 0.7rem;
    color: var(--muted);
    max-width: 74ch;
  }

  .feature__body :global(p:last-child) {
    margin-bottom: 0;
  }

  .feature__link {
    justify-self: start;
    color: var(--era, var(--accent));
    font-weight: 700;
    text-decoration: none;
  }

  .feature__link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .proj {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--surface) 70%, transparent);
  }

  .proj summary {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem 0.9rem;
    padding: 0.7rem 0.9rem;
    cursor: pointer;
    list-style: none;
    min-height: 44px;
  }

  .proj summary::-webkit-details-marker {
    display: none;
  }

  .proj__name {
    font-weight: 700;
  }

  .proj summary .proj-period {
    margin: 0;
  }

  .proj__skills {
    color: var(--muted);
    font-size: 0.82rem;
  }

  .proj__chevron {
    margin-left: auto;
    color: var(--era);
    font-weight: 800;
    font-size: 1.1rem;
    transition: transform 140ms ease;
  }

  .proj[open] .proj__chevron {
    transform: rotate(45deg);
  }

  .proj summary:hover {
    background: color-mix(in srgb, var(--surface-alt) 70%, transparent);
  }

  .proj__body {
    padding: 0.2rem 0.9rem 0.9rem;
    border-top: 1px solid var(--border);
  }

  .proj__body :global(p) {
    margin: 0.7rem 0 0;
    color: var(--muted);
    max-width: 74ch;
  }

  .tech-section {
    margin-top: clamp(2.4rem, 5vw, 4rem);
    border-top: 1px solid var(--border);
    padding-top: clamp(1.6rem, 3.5vw, 2.6rem);
  }

  .tech-map {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.9rem;
  }

  .tech-map article {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    padding: 0.95rem 1.05rem;
  }

  .tech-map h3 {
    margin: 0 0 0.35rem;
    font-size: 1.02rem;
  }

  .tools {
    margin: 0 0 0.35rem;
    color: var(--accent-soft);
    font-size: 0.88rem;
  }

  .tech-map p:not(.tools) {
    margin: 0;
    color: var(--muted);
    font-size: 0.92rem;
  }

  @media (max-width: 900px) {
    .highlight-strip {
      grid-template-columns: 1fr 1fr;
    }

    .highlight-strip article:nth-child(2n) {
      border-right: 0;
    }

    .highlight-strip article:nth-child(-n + 2) {
      border-bottom: 1px solid var(--border);
    }

    .tech-map {
      grid-template-columns: 1fr;
    }

    .era__head {
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-end;
      gap: 0.4rem;
    }
  }

  @media (max-width: 600px) {
    .highlight-strip {
      grid-template-columns: 1fr;
    }

    .highlight-strip article {
      border-right: 0;
      border-bottom: 1px solid var(--border);
    }

    .highlight-strip article:last-child {
      border-bottom: 0;
    }

    .proj summary {
      gap: 0.2rem 0.6rem;
    }

    .proj__skills {
      width: 100%;
      order: 3;
    }
  }
</style>
