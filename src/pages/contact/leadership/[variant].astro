---
import { getCollection } from 'astro:content'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import EmailObfuscated from '../../../components/EmailObfuscated.astro'

export function getStaticPaths() {
  return [
    { params: { variant: 'control' }, props: { label: 'Control homepage' } },
    { params: { variant: 'em-home' }, props: { label: 'Engineering manager homepage' } },
  ]
}

interface Props {
  label: string
}

const { label } = Astro.props
const contactEntry = (await getCollection('contact'))[0]

if (!contactEntry) {
  throw new Error('Required contact content is missing.')
}

const displayEmail = `${contactEntry.data.emailLocal}@${contactEntry.data.emailDomain}`
---

<BaseLayout
  title="Nicholas M. T. Elliott | Leadership Contact"
  description="Contact Nicholas M.T. Elliott about Director / Head of Engineering roles, delivery leadership, platform architecture, or technical leadership needs."
  canonicalPath="/contact/leadership/"
>
  <section class="contact-card card">
    <p class="eyebrow">Contact · {label}</p>
    <h1>Tell me about the role.</h1>
    <p>
      The useful version of a first conversation has context in it: the team, the product, what's working, what
      isn't, and what kind of engineering leadership you're actually looking for. Email is best.
    </p>
    <div class="contact-actions">
      <EmailObfuscated displayEmail={displayEmail} aliasTag="leadership" />
      <a class="button-secondary" href={contactEntry.data.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
      <a class="button-secondary" href="/portfolio">Portfolio</a>
    </div>
  </section>
</BaseLayout>

<style lang="scss">
  .contact-card {
    max-width: min(780px, 100%);
    margin: clamp(1rem, 4vw, 3rem) auto;
    padding: clamp(1.2rem, 4vw, 2.4rem);
  }

  .contact-card h1 {
    margin: 0.6rem 0 1rem;
    font-size: clamp(2.2rem, 5vw, 4.2rem);
    line-height: 0.98;
    max-width: 12ch;
  }

  .contact-card p:not(.eyebrow) {
    color: var(--muted);
    max-width: 68ch;
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    margin-top: 1.4rem;
  }
</style>
