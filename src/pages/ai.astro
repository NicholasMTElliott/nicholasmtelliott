---
import BaseLayout from '../layouts/BaseLayout.astro'
import { openSourceRepos } from '../data/portfolio'

const aiTracks = [
  {
    title: 'Root Cause, in production',
    body: 'Led delivery of Root Cause for GHX Fields at Syngenta North America. It analyzes agronomic and environmental patterns across 90,000 fields a week and surfaces concerns with suggested mitigations — before the grower has to ask.',
  },
  {
    title: 'AI-generated reports',
    body: 'Built report-generation pipelines where LLM output is grounded in operational data and reviewed before it reaches a client. Narrative quality matters less than being checkably right.',
  },
  {
    title: 'AI-assisted engineering',
    body: 'Rolled out AI-assisted development at Skyward — coding agents for senior engineers on large codebases, with the same code-review bar as human-written changes.',
  },
  {
    title: 'Local models',
    body: 'Run hosted-versus-local comparisons with Ollama and vLLM. For some client data, the privacy answer decides the architecture before cost or latency get a vote.',
  },
]

const rootCauseFacts = [
  ['Shipped', '2026, Syngenta North America'],
  ['Scale', '90,000 fields analyzed weekly'],
  ['Reach', 'Actionable findings for 90% of growers'],
  ['Impact', 'Dozens of hours saved per grower'],
]

const principles = [
  'AI should sharpen decisions, not hide uncertainty.',
  'Generated output needs a review path and observable failure modes.',
  'Developer AI earns its place by improving flow, not replacing judgment.',
  'Hosted and local models trade privacy, cost, and operations differently.',
]
---

<BaseLayout
  title="Nicholas M. T. Elliott | AI Work"
  description="Production AI, AI-assisted engineering practices, report generation, and local model investigation from Nicholas M.T. Elliott."
>
  <section class="ai-hero">
    <div>
      <p class="eyebrow">AI in production</p>
      <h1>90,000 fields a week.</h1>
      <p>
        That's what Root Cause, the AI feature my team shipped for Syngenta, analyzes in production every week. I've
        also built AI report pipelines, rolled out coding agents across an engineering team, and run local models on
        my own hardware to understand the tradeoffs firsthand.
      </p>
      <div class="button-row">
        <a class="button" href="/case-studies/global-ag-platform">See the platform context</a>
        <a class="button-secondary" href="https://github.com/NicholasMTElliott" target="_blank" rel="noreferrer">GitHub</a>
      </div>
    </div>
    <aside class="ai-console card">
      <p class="eyebrow">Root Cause</p>
      <dl>
        {
          rootCauseFacts.map(([label, value]) => (
            <div>
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))
        }
      </dl>
    </aside>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">The work</p>
      <h2>Four ways I use AI</h2>
    </div>
    <div class="track-grid">
      {
        aiTracks.map(track => (
          <article class="track card">
            <h3>{track.title}</h3>
            <p>{track.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section production-ai">
    <div class="section-heading">
      <p class="eyebrow">How Root Cause works</p>
      <h2>Data in, judgment out</h2>
      <p>
        The AI sits in the middle of an existing agronomic workflow. It gets growers to a problem earlier; the
        decision about what to do stays with people who know the field.
      </p>
    </div>
    <div class="system-flow">
      <article><strong>Operational Data</strong><span>field, weather, crop, agronomic, and environmental signals</span></article>
      <article><strong>Analysis Layer</strong><span>AI-assisted pattern interpretation and concern surfacing</span></article>
      <article><strong>Human Decision</strong><span>mitigations, field review, recommendation context, and follow-up</span></article>
    </div>
  </section>

  <section class="section principles">
    <div class="section-heading">
      <p class="eyebrow">Principles</p>
      <h2>What I hold AI work to</h2>
    </div>
    <ol>
      {principles.map(principle => <li>{principle}</li>)}
    </ol>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Open source</p>
      <h2>Tools I've published</h2>
      <p>
        Small, working tools from my own AI workflows — agent task boards, image-generation wrappers, local-model
        experiments.
      </p>
    </div>
    <div class="repo-grid">
      {
        openSourceRepos.map(repo => (
          <article class="repo card">
            <h3><a href={repo.href} target="_blank" rel="noreferrer">{repo.name}</a></h3>
            <p>{repo.summary}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style lang="scss">
  .ai-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.75fr);
    gap: clamp(1rem, 3vw, 2rem);
    align-items: stretch;
    padding-top: clamp(1rem, 3vw, 2rem);
  }

  .ai-hero > div {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    min-height: clamp(430px, 62vh, 620px);
    padding: clamp(1.35rem, 4vw, 3rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    background:
      linear-gradient(rgba(13, 16, 23, 0.28), rgba(13, 16, 23, 0.92)),
      url('/images/generated/ai-platform-hero.webp') center / cover;
    box-shadow: var(--shadow);
  }

  .ai-hero h1 {
    max-width: 11ch;
    margin: 0.7rem 0 1rem;
    font-size: clamp(3rem, 7vw, 5.7rem);
    line-height: 0.92;
  }

  .ai-hero p {
    max-width: 72ch;
    color: var(--muted);
    font-size: clamp(1rem, 1.7vw, 1.22rem);
  }

  .ai-console {
    align-self: stretch;
    display: block;
    padding-top: 1.1rem;
  }

  dl {
    display: grid;
    gap: 1rem;
    margin: 1.3rem 0 0;
  }

  dl div {
    border: 1px solid var(--border);
    background: var(--surface-alt);
    padding: 1rem;
  }

  dt {
    color: var(--accent-warm);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  dd {
    margin: 0.35rem 0 0;
    color: var(--muted);
  }

  .section {
    margin-top: clamp(2.2rem, 5vw, 4rem);
  }

  .track-grid,
  .repo-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .track,
  .repo {
    min-height: 230px;
  }

  .track h3,
  .repo h3 {
    margin: 0 0 0.8rem;
  }

  .track p,
  .repo p,
  .repo span {
    color: var(--muted);
  }

  .repo span {
    display: block;
    margin-top: 0.85rem;
    font-size: 0.86rem;
  }

  .production-ai {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: clamp(1.2rem, 3vw, 2rem);
    background:
      linear-gradient(rgba(13, 16, 23, 0.35), rgba(13, 16, 23, 0.92)),
      url('/images/generated/ai-platform-hero.webp') center / cover;
  }

  .system-flow {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1.2rem;
  }

  .system-flow article {
    border: 1px solid color-mix(in srgb, var(--border) 70%, var(--accent) 30%);
    background: color-mix(in srgb, var(--bg) 78%, transparent);
    padding: 1rem;
  }

  .system-flow strong,
  .system-flow span {
    display: block;
  }

  .system-flow span {
    margin-top: 0.35rem;
    color: var(--muted);
  }

  .principles ol {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    padding: 0;
    margin: 0;
    list-style: none;
    counter-reset: principle;
  }

  .principles li {
    counter-increment: principle;
    border: 1px solid var(--border);
    background: var(--surface);
    border-radius: var(--radius);
    padding: 1rem;
    color: var(--muted);
  }

  .principles li::before {
    content: counter(principle, decimal-leading-zero);
    display: block;
    color: var(--accent-warm);
    font-weight: 800;
    margin-bottom: 0.6rem;
  }

  @media (max-width: 980px) {
    .ai-hero,
    .track-grid,
    .repo-grid,
    .system-flow,
    .principles ol {
      grid-template-columns: 1fr 1fr;
    }

    .ai-hero > div,
    .ai-console {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 640px) {
    .ai-hero,
    .track-grid,
    .repo-grid,
    .system-flow,
    .principles ol {
      grid-template-columns: 1fr;
    }

    .ai-hero h1 {
      max-width: 12ch;
      font-size: clamp(2.5rem, 15vw, 4rem);
    }
  }
</style>
