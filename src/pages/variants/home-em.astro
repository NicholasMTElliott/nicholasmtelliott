---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import EmailObfuscated from '../../components/EmailObfuscated.astro'
import SignalGlyph from '../../components/SignalGlyph.astro'
import { proofMetrics, selectedAchievements, valuePillars } from '../../data/portfolio'

const profileEntry = (await getCollection('profile'))[0]
const contactEntry = (await getCollection('contact'))[0]
const defaultAvatarUrl = 'https://gravatar.com/avatar/468788fd550c4128b0c250566ea8729f?s=160'
const displayEmail = contactEntry ? `${contactEntry.data.emailLocal}@${contactEntry.data.emailDomain}` : null

if (!profileEntry) {
  throw new Error('Required profile content is missing.')
}

const careerSignals = [
  ['Skyward', 'Founder/operator, 30-person engineering org'],
  ['Syngenta', 'Global Fortune 500 platform delivery'],
  ['$3.4M', 'Peak annual Skyward revenue'],
  ['Global teams', 'US, India, Brazil, Egypt, Europe'],
  ['AI', 'Production Root Cause feature'],
]
---

<BaseLayout
  title="Nicholas M. T. Elliott | Engineering Management"
  description="Engineering manager and director-level leader focused on hiring, delivery accountability, stakeholder trust, and durable platform execution."
  canonicalPath="/"
>
  <section class="hero">
    <div class="hero__content">
      <p class="eyebrow">Director / Head of Engineering candidate</p>
      <h1>Career evidence before slogans.</h1>
      <p class="hero__lead">
        I founded and scaled Skyward, led long-running enterprise delivery for Syngenta-scale systems, and stayed close
        enough to architecture, operations, and AI work to make technical leadership credible.
      </p>
      <div class="button-row">
        <a class="button" href="/portfolio">Review delivery history</a>
        <a class="button-secondary" href="/contact/leadership/em-home/">Contact me</a>
        <a class="button-secondary" href={profileEntry.data.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
      </div>
      {displayEmail && (
        <div class="hero__email">
          <EmailObfuscated displayEmail={displayEmail} aliasTag="bot" />
        </div>
      )}
    </div>

    <aside class="proof card" aria-label="Career proof points">
      <img class="proof__avatar" src={profileEntry.data.avatarUrl ?? defaultAvatarUrl} alt={profileEntry.data.fullName} />
      <div>
        <p class="eyebrow">Resume snapshot</p>
        <h3>Nicholas M.T. Elliott</h3>
        <p>{profileEntry.data.headline} · {profileEntry.data.location}</p>
      </div>
      <ul>
        {
          proofMetrics.map(metric => (
            <li>
              <strong>{metric.value}</strong>
              <span>{metric.label}</span>
            </li>
          ))
        }
      </ul>
    </aside>
  </section>

  <section class="signal-strip" aria-label="Career evidence">
    {
      careerSignals.map(([label, detail]) => (
        <article>
          <strong>{label}</strong>
          <span>{detail}</span>
        </article>
      ))
    }
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Selected accomplishments</p>
      <h2>What I have actually led.</h2>
    </div>
    <div class="achievement-grid">
      {
        selectedAchievements.map(achievement => (
          <article class="achievement card">
            <h3>{achievement.title}</h3>
            <dl>
              <div>
                <dt>Role</dt>
                <dd>{achievement.role}</dd>
              </div>
              <div>
                <dt>Outcome</dt>
                <dd>{achievement.outcome}</dd>
              </div>
              <div>
                <dt>Scale</dt>
                <dd>{achievement.scale}</dd>
              </div>
            </dl>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Operating range</p>
      <h2>Clear ownership, credible technical guidance, and disciplined delivery.</h2>
    </div>
    <div class="pillar-grid">
      {
        valuePillars.map(pillar => (
          <article class="pillar card">
            <SignalGlyph type={pillar.icon} label={`${pillar.title} signal glyph`} />
            <h3>{pillar.title}</h3>
            <p>{pillar.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section featured-case">
    <div class="case-visual card">
      <p class="eyebrow">Featured proof</p>
      <h2>Enterprise Platform Delivery</h2>
      <p>Long-running work where people leadership, stakeholder alignment, architecture, and operations had to hold together.</p>
    </div>
    <div class="case-copy">
      <div class="section-heading">
        <p class="eyebrow">Syngenta · GHX Fields / E-Luminate / Cropwise ecosystem</p>
        <h2>A concrete example of the work behind the headline.</h2>
        <p>
          I coordinated client stakeholders and distributed engineering groups while guiding modernization across web
          apps, integrations, AWS infrastructure, observability, and product AI. The practical value was making a
          complex platform operable, explainable, and transferable to internal ownership.
        </p>
      </div>
      <div class="case-points">
        <article>
          <span class="eyebrow">Team</span>
          <p>Scaled from solo execution to multi-team delivery with mentorship, ownership, and low turnover.</p>
        </article>
        <article>
          <span class="eyebrow">Delivery</span>
          <p>Managed long-running stakeholder expectations across product, client, and globally distributed engineering groups.</p>
        </article>
        <article>
          <span class="eyebrow">Systems</span>
          <p>Kept architecture decisions connected to reliability, audit readiness, and handoff to internal teams.</p>
        </article>
      </div>
      <a class="button" href="/case-studies/global-ag-platform">Open detailed case study</a>
    </div>
  </section>
</BaseLayout>

<style lang="scss">
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.18fr) minmax(310px, 0.82fr);
    gap: clamp(1rem, 3vw, 2.4rem);
    align-items: stretch;
    min-height: clamp(560px, 72vh, 760px);
    padding: clamp(1.1rem, 3vw, 2.25rem) 0 0;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 100%;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: clamp(1.35rem, 4vw, 3.2rem);
    background-image: linear-gradient(rgba(13, 16, 23, 0.1), rgba(13, 16, 23, 0.9)),
      url('/images/generated/enterprise-hero.webp');
    background-size: cover;
    background-position: center;
    box-shadow: var(--shadow);
  }

  .hero h1 {
    max-width: 13ch;
    margin: 0.7rem 0 1rem;
    font-size: clamp(3rem, 7vw, 5.9rem);
    line-height: 0.92;
  }

  .hero__lead {
    max-width: 68ch;
    color: color-mix(in srgb, var(--text) 86%, var(--muted) 14%);
    font-size: clamp(1.02rem, 1.8vw, 1.26rem);
    margin: 0 0 1.3rem;
  }

  .hero__email {
    margin-top: 1rem;
  }

  .proof {
    display: grid;
    align-content: start;
    gap: 1.1rem;
  }

  .proof__avatar {
    width: clamp(74px, 8vw, 96px);
    height: clamp(74px, 8vw, 96px);
    border-radius: 50%;
    border: 2px solid color-mix(in srgb, var(--accent) 48%, transparent);
  }

  .proof h3 {
    margin: 0.35rem 0 0;
    font-size: clamp(1.35rem, 2vw, 1.7rem);
  }

  .proof p {
    margin: 0.25rem 0 0;
    color: var(--muted);
  }

  .proof ul {
    display: grid;
    gap: 0.85rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .proof li {
    display: grid;
    grid-template-columns: minmax(74px, 0.3fr) 1fr;
    gap: 0.9rem;
    border-top: 1px solid var(--border);
    padding-top: 0.85rem;
  }

  .proof strong {
    color: var(--accent-warm);
    font-size: clamp(1.25rem, 2.4vw, 1.7rem);
    line-height: 1;
  }

  .proof span {
    color: var(--muted);
  }

  .signal-strip {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    margin-top: clamp(1rem, 2vw, 1.4rem);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: color-mix(in srgb, var(--surface) 78%, #000 22%);
  }

  .signal-strip article {
    padding: 1rem;
    border-right: 1px solid var(--border);
  }

  .signal-strip article:last-child {
    border-right: 0;
  }

  .signal-strip strong,
  .signal-strip span {
    display: block;
  }

  .signal-strip span {
    color: var(--muted);
    font-size: 0.88rem;
    margin-top: 0.2rem;
  }

  .section {
    margin-top: clamp(2.2rem, 5vw, 4.2rem);
  }

  .achievement-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .achievement {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .achievement h3 {
    margin: 0;
    font-size: clamp(1.2rem, 2vw, 1.55rem);
  }

  .achievement dl {
    display: grid;
    gap: 0.85rem;
    margin: 0;
  }

  .achievement dl div {
    border-top: 1px solid var(--border);
    padding-top: 0.85rem;
  }

  .achievement dt {
    color: var(--accent-warm);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .achievement dd {
    margin: 0.25rem 0 0;
    color: var(--muted);
  }

  .pillar-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .pillar {
    min-height: 210px;
    display: grid;
    align-content: start;
    gap: 0.75rem;
    position: relative;
    overflow: hidden;
    transition:
      border-color 140ms ease,
      background-color 140ms ease,
      transform 140ms ease;
  }

  .pillar::after {
    content: '';
    position: absolute;
    inset: auto 0 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--accent) 45%, transparent), transparent);
    opacity: 0;
    transition: opacity 140ms ease;
  }

  .pillar:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--border) 52%, var(--accent) 48%);
    background: color-mix(in srgb, var(--surface) 88%, var(--surface-alt) 12%);
  }

  .pillar:hover::after {
    opacity: 1;
  }

  .pillar h3 {
    margin: 0 0 0.75rem;
  }

  .pillar p {
    color: var(--muted);
  }

  .featured-case {
    display: grid;
    grid-template-columns: minmax(280px, 0.82fr) minmax(0, 1.18fr);
    gap: clamp(1rem, 3vw, 2rem);
  }

  .case-visual {
    min-height: 410px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background:
      linear-gradient(rgba(13, 16, 23, 0.08), rgba(13, 16, 23, 0.88)),
      url('/images/generated/ag-platform-architecture.webp') center / cover;
  }

  .case-visual h2 {
    margin: 0.5rem 0;
    font-size: clamp(1.8rem, 3.6vw, 3rem);
  }

  .case-visual p {
    margin: 0;
    color: color-mix(in srgb, var(--text) 82%, var(--muted) 18%);
  }

  .case-copy {
    align-self: center;
  }

  .case-points {
    display: grid;
    gap: 0.85rem;
    margin: 1.25rem 0;
  }

  .case-points article {
    border-top: 1px solid var(--border);
    padding-top: 0.85rem;
  }

  .case-points p {
    margin: 0.3rem 0 0;
    color: var(--muted);
  }

  @media (max-width: 980px) {
    .hero,
    .featured-case {
      grid-template-columns: 1fr;
      min-height: 0;
    }

    .achievement-grid,
    .signal-strip,
    .pillar-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .signal-strip article:nth-child(2n) {
      border-right: 0;
    }
  }

  @media (max-width: 640px) {
    .hero h1 {
      max-width: 12ch;
      font-size: clamp(2.55rem, 16vw, 4rem);
    }

    .achievement-grid,
    .signal-strip,
    .pillar-grid {
      grid-template-columns: 1fr;
    }

    .signal-strip article {
      border-right: 0;
      border-bottom: 1px solid var(--border);
    }

    .signal-strip article:last-child {
      border-bottom: 0;
    }
  }
</style>
